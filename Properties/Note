
using Cronos;

namespace Certify.Alerting.Service.Alerts.Jobs;

public interface IJobSchedule
{
    DateTime GetNextRunTimeUtc(
        DateTime nowUtc,
        string cronExpression);
}

public sealed class JobSchedule : IJobSchedule
{
    public DateTime GetNextRunTimeUtc(
        DateTime nowUtc,
        string cronExpression)
    {
        var expression = CronExpression.Parse(
            cronExpression,
            CronFormat.Standard);

        return expression.GetNextOccurrence(
                   nowUtc,
                   TimeZoneInfo.Utc,
                   inclusive: false)
               ?? throw new InvalidOperationException(
                   $"Unable to calculate the next occurrence for cron expression '{cronExpression}'.");
    }
}


[Fact]
public async Task DoesNotUpdateMetadata_WhenPollingMessagePublishingFails()
{
    // Arrange
    await using var setupApp = _fixture.CreateApplication();

    await ResetJobMetadata(setupApp.Services);

    var dueTimeUtc = await SetJobDue(setupApp.Services);

    var publishAttempted = new TaskCompletionSource<bool>(
        TaskCreationOptions.RunContinuationsAsynchronously);

    var publisher = Substitute.For<ICertifyPublisher>();

    publisher
        .PublishEvent(
            Arg.Any<ExpiringPhysicalStampsPollingScheduledMessage>(),
            ExpiringPhysicalStampsPollingScheduledMessage.RoutingKey,
            Arg.Any<CertifyPublishOptions>())
        .Returns(_ =>
        {
            publishAttempted.TrySetResult(true);

            return Task.FromException(
                new InvalidOperationException(
                    "Simulated message publishing failure."));
        });

    EnableExpiringPhysicalStampsJob();

    await using var app = _fixture.CreateApplication(services =>
    {
        services.RemoveAll<ICertifyPublisher>();
        services.AddSingleton(publisher);
    });

    // Act
    await publishAttempted.Task.WaitAsync(
        TimeSpan.FromSeconds(20));

    // Assert
    var metadata = await GetJobMetadata(app.Services);

    metadata.Should().NotBeNull();

    metadata!.NextRunTimeUtc.Should().NotBeNull();

    metadata.NextRunTimeUtc!.Value.Should().BeCloseTo(
        dueTimeUtc,
        TimeSpan.FromSeconds(3),
        "metadata should not advance when the polling message cannot be published");
}




using System.Text.Json;
using DLR.Certify.MessageBus.Abstractions;
using DLR.Certify.MessageBus.Models;
using FluentAssertions;
using NSubstitute;

namespace Certify.Alerting.Service.Tests.Features
    .ExpiringPhysicalStamps;

public sealed class
    ExpiringPhysicalStampsPollingScheduledMessageHandlerTests
{
    [Fact]
    public async Task Throws_WhenCodeServicePollingFails()
    {
        // Arrange
        const int expiryWindowInDays = 30;

        var pollingService = Substitute.For<IPollingService>();

        pollingService
            .PollCodeService(
                expiryWindowInDays,
                Arg.Any<CancellationToken>())
            .Returns(Task.FromResult(false));

        var handler =
            new ExpiringPhysicalStampsPollingScheduledMessageHandler(
                pollingService);

        var body = JsonSerializer.Serialize(
            new ExpiringPhysicalStampsPollingScheduledMessage
            {
                ExpiryWindowInDays = expiryWindowInDays
            });

        var context =
            Substitute.For<
                ICertifyConsumeContext<CertifyEvent>>();

        context.Message.Returns(
            new CertifyEvent
            {
                SerialisedMessageBody = body
            });

        // Act
        Func<Task> act = () => handler.Consume(context);

        // Assert
        await act.Should()
            .ThrowAsync<InvalidOperationException>()
            .WithMessage(
                "*polling did not complete successfully*");

        await pollingService
            .Received(1)
            .PollCodeService(
                expiryWindowInDays,
                CancellationToken.None);
    }
}

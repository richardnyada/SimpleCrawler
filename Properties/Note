namespace Certify.Alerting.Service.Alerts.ExpiringPhysicalStamps;

public sealed class ExpiringPhysicalStampsPollingJob(
    ILogger<ExpiringPhysicalStampsPollingJob> logger,
    IHttpClientFactory httpClientFactory,
    IDistributedCache cache,
    IDistributedLockProvider lockProvider,
    IConfiguration configuration,
    IServiceScopeFactory serviceScopeFactory,
    IFeatureFlagService featureFlagService) : BackgroundService
{
    private const string GatewayServiceHttpClientName = "Gateway";
    private const string ExpiringCodesPathTemplate = "/codes/v1/expiringcodes/days/{0}";

    private const string JobName = "ExpiringPhysicalStampsPollingJob";
    private const string JobMetadataCacheKey = "job:metadata:ExpiringPhysicalStampsPollingJob";
    private const string JobLockKey = "job:lock:ExpiringPhysicalStampsPollingJob";

    private const string CheckIntervalSecondsConfigKey = "DistributedJobs:CheckIntervalSeconds";
    private const string LockTimeoutMinutesConfigKey = "DistributedJobs:LockTimeoutMinutes";

    private const int DefaultCheckIntervalSeconds = 30;
    private const int DefaultLockTimeoutMinutes = 10;
    private const int NextRunIntervalInDays = 1;
    private const int JobMetadataExpirationInDays = 30;

    private static readonly int[] ExpiryWindowInDays = [15];

    protected override async Task ExecuteAsync(CancellationToken stoppingToken)
    {
        logger.LogInformation("Expiring physical stamps polling hosted service started.");

        using var timer = new PeriodicTimer(GetCheckInterval());

        while (!stoppingToken.IsCancellationRequested)
        {
            try
            {
                await RunJobIfFeatureEnabled(stoppingToken);

                if (!await timer.WaitForNextTickAsync(stoppingToken))
                {
                    break;
                }
            }
            catch (OperationCanceledException) when (stoppingToken.IsCancellationRequested)
            {
                break;
            }
            catch (Exception exception)
            {
                logger.LogError(
                    exception,
                    "Unexpected error occurred while executing hosted service for job {JobName}.",
                    JobName);
            }
        }

        logger.LogInformation("Expiring physical stamps polling hosted service stopped.");
    }

    private async Task RunJobIfFeatureEnabled(CancellationToken cancellationToken)
    {
        var isFeatureEnabled = await featureFlagService.IsEnabled(
            FeatureFlags.ExpiringPhysicalStampsEnabled);

        if (!isFeatureEnabled)
        {
            return;
        }

        await TryRunJob(cancellationToken);
    }

    private async Task TryRunJob(CancellationToken cancellationToken)
    {
        var nowUtc = DateTime.UtcNow;
        var metadata = await GetJobMetadata(cancellationToken);

        if (!IsJobDue(metadata, nowUtc, out var nextRunTimeUtc))
        {
            logger.LogDebug(
                "Job {JobName} is not due yet. Next run time: {NextRunTimeUtc}.",
                JobName,
                nextRunTimeUtc);

            return;
        }

        await using var jobLock = await lockProvider
            .CreateLock(JobLockKey)
            .TryAcquireAsync(GetLockTimeout(), cancellationToken);

        if (jobLock is null)
        {
            logger.LogDebug(
                "Job {JobName} skipped because distributed lock {JobLockKey} could not be acquired.",
                JobName,
                JobLockKey);

            return;
        }

        nowUtc = DateTime.UtcNow;
        metadata = await GetJobMetadata(cancellationToken);

        if (!IsJobDue(metadata, nowUtc, out nextRunTimeUtc))
        {
            logger.LogDebug(
                "Job {JobName} is no longer due after acquiring the distributed lock. Next run time: {NextRunTimeUtc}.",
                JobName,
                nextRunTimeUtc);

            return;
        }

        logger.LogInformation(
            "Job {JobName} acquired distributed lock and will run.",
            JobName);

        var pollingSucceeded = await PollCodeService(cancellationToken);

        if (!pollingSucceeded)
        {
            logger.LogWarning(
                "Job {JobName} did not complete successfully. Job metadata will not be updated.",
                JobName);

            return;
        }

        var completedAtUtc = DateTime.UtcNow;
        var nextRunUtc = completedAtUtc.AddDays(NextRunIntervalInDays);

        await SetJobMetadata(
            new ExpiringPhysicalStampsJobMetadata
            {
                NextRunTimeUtc = nextRunUtc,
                LastSuccessfulRunUtc = completedAtUtc
            },
            cancellationToken);

        logger.LogInformation(
            "Job {JobName} completed successfully. Next run time: {NextRunTimeUtc}.",
            JobName,
            nextRunUtc);
    }

    private async Task<bool> PollCodeService(CancellationToken cancellationToken)
    {
        var correlationId = Guid.NewGuid();

        try
        {
            var client = httpClientFactory.CreateClient(GatewayServiceHttpClientName);

            using var scope = serviceScopeFactory.CreateScope();
            var alertPublisher = scope.ServiceProvider
                .GetRequiredService<IExpiringPhysicalStampsAlertPublisher>();

            foreach (var days in ExpiryWindowInDays)
            {
                var sites = await GetSitesWithExpiringCodes(
                    client,
                    days,
                    correlationId,
                    cancellationToken);

                var sitesWithPhysicalStamps = GetSitesWithPhysicalStamps(sites);

                foreach (var site in sitesWithPhysicalStamps)
                {
                    logger.LogInformation(
                        "CorrelationId: {CorrelationId}. SiteId: {SiteId}, SiteName: {SiteName}, SiteGln: {SiteGln}, Code Count: {CodeCount}, Days: {Days}. Publishing expiring physical stamp alert event.",
                        correlationId,
                        site.Site.SiteId,
                        site.Site.SiteName,
                        site.Site.SiteGln,
                        site.PhysicalCodes.Count,
                        days);

                    await alertPublisher.PublishAlert(
                        site.Site.SiteId,
                        days,
                        correlationId);
                }
            }

            return true;
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
            throw;
        }
        catch (Exception exception)
        {
            logger.LogError(
                exception,
                "CorrelationId: {CorrelationId}. Error occurred while polling Code Service for expiring physical stamps.",
                correlationId);

            return false;
        }
    }

    private async Task<List<CodeServiceExpiringCodesResponse>> GetSitesWithExpiringCodes(
        HttpClient client,
        int days,
        Guid correlationId,
        CancellationToken cancellationToken)
    {
        var path = string.Format(ExpiringCodesPathTemplate, days);

        logger.LogInformation(
            "CorrelationId: {CorrelationId}. Polling Code Service for expiring physical stamps. Days: {Days}.",
            correlationId,
            days);

        using var request = new HttpRequestMessage(HttpMethod.Get, path);
        request.Headers.Add(CorrelationHeader.CorrelationId, correlationId.ToString());

        using var response = await client.SendAsync(request, cancellationToken);
        response.EnsureSuccessStatusCode();

        return await response.Content.ReadFromJsonAsync<List<CodeServiceExpiringCodesResponse>>(
            cancellationToken) ?? [];
    }

    private static List<SiteWithPhysicalStamps> GetSitesWithPhysicalStamps(
        IEnumerable<CodeServiceExpiringCodesResponse> sites)
    {
        return sites
            .Select(site => new SiteWithPhysicalStamps(
                site,
                site.ExpiringCodes
                    .Where(code => IsPhysical(code.CodeType))
                    .ToList()))
            .Where(site => site.PhysicalCodes.Count > 0)
            .ToList();
    }

    private async Task<ExpiringPhysicalStampsJobMetadata?> GetJobMetadata(
        CancellationToken cancellationToken)
    {
        return await cache.GetAsync<ExpiringPhysicalStampsJobMetadata>(
            JobMetadataCacheKey,
            cancellationToken);
    }

    private async Task SetJobMetadata(
        ExpiringPhysicalStampsJobMetadata metadata,
        CancellationToken cancellationToken)
    {
        await cache.SetAsync(
            JobMetadataCacheKey,
            metadata,
            absoluteExpiration: TimeSpan.FromDays(JobMetadataExpirationInDays),
            cancellationToken: cancellationToken);
    }

    private TimeSpan GetCheckInterval()
    {
        return TimeSpan.FromSeconds(
            configuration.GetValue(CheckIntervalSecondsConfigKey, DefaultCheckIntervalSeconds));
    }

    private TimeSpan GetLockTimeout()
    {
        return TimeSpan.FromMinutes(
            configuration.GetValue(LockTimeoutMinutesConfigKey, DefaultLockTimeoutMinutes));
    }

    private static bool IsJobDue(
        ExpiringPhysicalStampsJobMetadata? metadata,
        DateTime nowUtc,
        out DateTime? nextRunTimeUtc)
    {
        nextRunTimeUtc = metadata?.NextRunTimeUtc;

        return nextRunTimeUtc is null || nowUtc >= nextRunTimeUtc.Value;
    }

    private static bool IsPhysical(string codeType)
    {
        return string.Equals(codeType, "Physical", StringComparison.OrdinalIgnoreCase)
            || string.Equals(codeType, "Ucode", StringComparison.OrdinalIgnoreCase);
    }

    private sealed record SiteWithPhysicalStamps(
        CodeServiceExpiringCodesResponse Site,
        List<CodeServiceExpiringCodeResponse> PhysicalCodes);

    private sealed class ExpiringPhysicalStampsJobMetadata
    {
        public DateTime? NextRunTimeUtc { get; set; }

        public DateTime? LastSuccessfulRunUtc { get; set; }
    }
}

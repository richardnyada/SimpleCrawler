namespace Certify.Alerting.Service.Alerts.ExpiringPhysicalStamps
    .ExpiringPhysicalStampsJob;

public sealed class ExpiringPhysicalStampsPollingScheduledMessage
{
    public const string RoutingKey =
        "alert.expiringphysicalstampspolling";

    public required int ExpiryWindowInDays { get; init; }
}


using System.Text.Json;
using DLR.Certify.MessageBus.Abstractions;
using DLR.Certify.MessageBus.Attributes;
using DLR.Certify.MessageBus.Models;

namespace Certify.Alerting.Service.Alerts.ExpiringPhysicalStamps
    .ExpiringPhysicalStampsJob;

[ConsumerOptions(
    QueueName = "alerting-expiringphysicalstamps-polling",
    RoutingKey =
        ExpiringPhysicalStampsPollingScheduledMessage.RoutingKey)]
public sealed class ExpiringPhysicalStampsPollingScheduledMessageHandler(
    IPollingService pollingService)
    : ICertifyConsumer<CertifyEvent>
{
    public async Task Consume(
        ICertifyConsumeContext<CertifyEvent> context)
    {
        var body = context.Message.SerialisedMessageBody;

        if (string.IsNullOrWhiteSpace(body))
        {
            throw new ArgumentException(
                "Received an empty Expiring Physical Stamps polling message.");
        }

        var message =
            JsonSerializer.Deserialize<
                ExpiringPhysicalStampsPollingScheduledMessage>(body);

        if (message is null ||
            message.ExpiryWindowInDays <= 0)
        {
            throw new ArgumentException(
                "Received an invalid Expiring Physical Stamps polling message.");
        }

        var pollingSucceeded =
            await pollingService.PollCodeService(
                message.ExpiryWindowInDays,
                CancellationToken.None);

        if (!pollingSucceeded)
        {
            throw new InvalidOperationException(
                "Expiring Physical Stamps polling did not complete successfully.");
        }
    }
}





var messagePublished =
    await TryPublishPollingMessage(
        expiryWindowInDays,
        cancellationToken);


private async Task<bool> TryPublishPollingMessage(
    int expiryWindowInDays,
    CancellationToken cancellationToken)
{
    try
    {
        cancellationToken.ThrowIfCancellationRequested();

        using var scope =
            serviceScopeFactory.CreateScope();

        var publisher =
            scope.ServiceProvider
                .GetRequiredService<ICertifyPublisher>();

        var message =
            new ExpiringPhysicalStampsPollingScheduledMessage
            {
                ExpiryWindowInDays = expiryWindowInDays
            };

        var options =
            new CertifyPublishOptions
            {
                CorrelationId = Guid.NewGuid()
            };

        await publisher.PublishEvent(
            message,
            ExpiringPhysicalStampsPollingScheduledMessage.RoutingKey,
            options);

        return true;
    }
    catch (OperationCanceledException)
        when (cancellationToken.IsCancellationRequested)
    {
        throw;
    }
    catch (Exception exception)
    {
        logger.LogError(
            exception,
            "Failed to publish the Expiring Physical Stamps polling message.");

        return false;
    }
}

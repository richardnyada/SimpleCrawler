[Fact]
public async Task DoesNotPollCodeServiceAgain_WhenAnotherInstanceHasAlreadyUpdatedTheSchedule()
{
    // Arrange
    await using var setupApp = _fixture.CreateApplication();

    await ResetJobMetadata(setupApp.Services);
    await SetJobDue(setupApp.Services);

    StubKeycloakTokenEndpoint(setupApp);
    StubExpiringCodesEndpointWithPhysicalCodesAndDelay(setupApp);

    var requestCountBeforeRun = GetExpiringCodesRequestCount(setupApp);

    EnableExpiringPhysicalStampsJob();

    await using var app1 = _fixture.CreateApplication();
    await using var app2 = _fixture.CreateApplication();

    // Act
    var firstInstanceCompletedJob = await WaitUntilAsync(
        async () =>
        {
            var metadata = await GetJobMetadata(app1.Services);

            return GetExpiringCodesRequestCount(app1) == requestCountBeforeRun + 1
                && metadata?.NextRunTimeUtc is not null
                && metadata.NextRunTimeUtc.Value > DateTime.UtcNow;
        },
        TimeSpan.FromSeconds(60));

    firstInstanceCompletedJob.Should().BeTrue(
        "one app instance should acquire the distributed lock, poll Code Service, and update the next run time");

    await Task.Delay(
        TimeSpan.FromSeconds(5),
        TestContext.Current.CancellationToken);

    // Assert
    GetExpiringCodesRequestCount(app1).Should().Be(
        requestCountBeforeRun + 1,
        "the second app instance may acquire the lock afterwards, but should re-check metadata and not poll Code Service again");

    var jobMetadata = await GetJobMetadata(app1.Services);

    jobMetadata.Should().NotBeNull();
    jobMetadata!.NextRunTimeUtc.Should().NotBeNull();
    jobMetadata.NextRunTimeUtc!.Value.Should().BeAfter(DateTime.UtcNow);
}

private static void StubExpiringCodesEndpointWithPhysicalCodesAndDelay(AlertingTestApplication app)
{
    app.WireMock
        .Given(
            Request.Create()
                .WithPath(FifteenDaysExpiringCodesPath)
                .UsingGet())
        .RespondWith(
            Response.Create()
                .WithStatusCode(HttpStatusCode.OK)
                .WithHeader("Content-Type", "application/json")
                .WithDelay(TimeSpan.FromSeconds(3))
                .WithBodyAsJson(
                    new[]
                    {
                        new
                        {
                            siteId = 123,
                            siteName = "Manufacturer 1 Site 1",
                            siteGln = "7311101.00001.00",
                            expiringCodes = new[]
                            {
                                new
                                {
                                    codeType = "Physical",
                                    Reference = "0000027",
                                    ExpiringDate = "2026-06-25T08:33:50.203Z"
                                }
                            }
                        }
                    }));
}


using AwesomeAssertions;
using Certify.Alerting.Service.Alerts.ExpiringPhysicalStamps;
using Microsoft.Extensions.Options;
using Xunit;

namespace Certify.Alerting.Service.Tests.Features.ExpiringPhysicalStamps;

public sealed class ExpiringPhysicalStampsJobScheduleTests
{
    [Fact]
    public void GetNextRunTimeUtc_WhenCurrentTimeIsBeforeConfiguredRunTime_ReturnsTodayAtConfiguredRunTime()
    {
        // Arrange
        var sut = CreateSut();
        var nowUtc = new DateTime(2026, 06, 16, 00, 30, 00, DateTimeKind.Utc);

        // Act
        var nextRunTimeUtc = sut.GetNextRunTimeUtc(nowUtc);

        // Assert
        nextRunTimeUtc.Should().Be(
            new DateTime(2026, 06, 16, 01, 00, 00, DateTimeKind.Utc));
    }

    [Fact]
    public void GetNextRunTimeUtc_WhenCurrentTimeIsExactlyConfiguredRunTime_ReturnsTomorrowAtConfiguredRunTime()
    {
        // Arrange
        var sut = CreateSut();
        var nowUtc = new DateTime(2026, 06, 16, 01, 00, 00, DateTimeKind.Utc);

        // Act
        var nextRunTimeUtc = sut.GetNextRunTimeUtc(nowUtc);

        // Assert
        nextRunTimeUtc.Should().Be(
            new DateTime(2026, 06, 17, 01, 00, 00, DateTimeKind.Utc));
    }

    [Fact]
    public void GetNextRunTimeUtc_WhenCurrentTimeIsAfterConfiguredRunTime_ReturnsTomorrowAtConfiguredRunTime()
    {
        // Arrange
        var sut = CreateSut();
        var nowUtc = new DateTime(2026, 06, 16, 12, 30, 00, DateTimeKind.Utc);

        // Act
        var nextRunTimeUtc = sut.GetNextRunTimeUtc(nowUtc);

        // Assert
        nextRunTimeUtc.Should().Be(
            new DateTime(2026, 06, 17, 01, 00, 00, DateTimeKind.Utc));
    }

    [Theory]
    [InlineData(3, 1, 60)]
    [InlineData(3, 0, 30)]
    [InlineData(2, 0, 30)]
    [InlineData(1, 1, 30)]
    [InlineData(1, 0, 5)]
    [InlineData(0, 45, 5)]
    [InlineData(0, 30, 1)]
    [InlineData(0, 10, 1)]
    public void GetNextCheckDelay_WhenNextRunTimeIsKnown_ReturnsExpectedDelay(
        int hoursUntilNextRun,
        int minutesUntilNextRun,
        int expectedDelayInMinutes)
    {
        // Arrange
        var sut = CreateSut();

        var nowUtc = new DateTime(2026, 06, 16, 12, 00, 00, DateTimeKind.Utc);
        var nextRunTimeUtc = nowUtc
            .AddHours(hoursUntilNextRun)
            .AddMinutes(minutesUntilNextRun);

        // Act
        var nextCheckDelay = sut.GetNextCheckDelay(nowUtc, nextRunTimeUtc);

        // Assert
        nextCheckDelay.Should().Be(TimeSpan.FromMinutes(expectedDelayInMinutes));
    }

    [Fact]
    public void GetNextCheckDelay_WhenNextRunTimeIsMissing_UsesCalculatedNextRunTime()
    {
        // Arrange
        var sut = CreateSut();

        var nowUtc = new DateTime(2026, 06, 16, 00, 30, 00, DateTimeKind.Utc);

        // Act
        var nextCheckDelay = sut.GetNextCheckDelay(nowUtc, nextRunTimeUtc: null);

        // Assert
        nextCheckDelay.Should().Be(
            TimeSpan.FromMinutes(1),
            "the next run time should be calculated as 01:00 UTC, which is 30 minutes away");
    }

    private static ExpiringPhysicalStampsJobSchedule CreateSut()
    {
        var options = new DistributedJobsOptions
        {
            LockTimeoutMinutes = 1,
            NextRunIntervalInDays = 1,
            JobMetadataExpirationInDays = 30,
            RunAtUtc = new TimeSpan(1, 0, 0)
        };

        return new ExpiringPhysicalStampsJobSchedule(
            new TestOptionsMonitor<DistributedJobsOptions>(options));
    }

    private sealed class TestOptionsMonitor<TOptions>(TOptions currentValue)
        : IOptionsMonitor<TOptions>
    {
        public TOptions CurrentValue { get; } = currentValue;

        public TOptions Get(string? name)
        {
            return CurrentValue;
        }

        public IDisposable OnChange(Action<TOptions, string?> listener)
        {
            return new NoopDisposable();
        }

        private sealed class NoopDisposable : IDisposable
        {
            public void Dispose()
            {
            }
        }
    }
}

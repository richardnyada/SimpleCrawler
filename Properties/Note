using Certify.Alerting.Service.Alerts.Jobs;
using Cronos;

namespace Certify.Alerting.Service.Alerts.ExpiringPhysicalStamps.ExpiringPhysicalStampsJob;

public static class ExpiringPhysicalStampsServiceCollectionExtensions
{
    public static IServiceCollection AddExpiringPhysicalStampsJobs(
        this IServiceCollection services)
    {
        services.AddSingleton<IScheduledRunExecutor, ScheduledRunExecutor>();
        services.AddSingleton<IScheduledRunTracker, ScheduledRunTracker>();
        services.AddSingleton<IJobMetadataStore, JobMetadataStore>();
        services.AddSingleton<ISchedulerLockProvider, SchedulerLockProvider>();

        services.AddScoped<IAlertPublisher, AlertPublisher>();
        services.AddScoped<IJobDueMessagePublisher, JobDueMessagePublisher>();
        services.AddScoped<IJobDueHandler, ExpiringPhysicalStampsJobDueHandler>();
        services.AddScoped<ICodeService, CodeService>();
        services.AddScoped<IPollingService, PollingService>();
        services.AddScoped<
            IExpiringPhysicalStampsNotificationPayloadBuilder,
            ExpiringPhysicalStampsNotificationPayloadBuilder>();

        services.AddOptions<ScheduledJobsOptions>()
            .BindConfiguration(ScheduledJobsOptions.SectionName)
            .ValidateDataAnnotations()
            .Validate(
                options => options.PollIntervalSeconds > 0,
                "The scheduled jobs poll interval must be greater than zero")
            .Validate(
                options => options.Jobs.Count > 0,
                "At least one scheduled job must be configured")
            .Validate(
                options => options.Jobs.All(job =>
                    !string.IsNullOrWhiteSpace(job.JobName)
                    && !string.IsNullOrWhiteSpace(job.CronExpression)),
                "Every scheduled job must have a job name and cron expression")
            .Validate(
                options => options.Jobs.All(job =>
                    IsValidCronExpression(job.CronExpression)),
                "Every scheduled job must have a valid cron expression")
            .Validate(
                options => options.Jobs
                    .Select(job => job.Key)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .Count() == options.Jobs.Count,
                "Every scheduled job must have a unique key")
            .ValidateOnStart();

        services.AddHostedService<ScheduledJobsService>();

        return services;
    }

    private static bool IsValidCronExpression(string cronExpression)
    {
        try
        {
            var numberOfParts = cronExpression
                .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Length;

            var format = numberOfParts == 6
                ? CronFormat.IncludeSeconds
                : CronFormat.Standard;

            CronExpression.Parse(cronExpression, format);

            return true;
        }
        catch (CronFormatException)
        {
            return false;
        }
    }
}

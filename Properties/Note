
using AwesomeAssertions;
using Certify.Alerting.Service.FeatureFlagging;
using Certify.Alerting.Service.Tests.Utils;
using System.Net;
using System.Text.Json;
using WireMock.RequestBuilders;
using WireMock.ResponseBuilders;
using Xunit;

namespace Certify.Alerting.Service.Tests.Features.ExpiringPhysicalStamps;

[Collection("AlertingTestInfrastructureCollection")]
public sealed class ExpiringPhysicalStampsPollingJobTests : IDisposable
{
    private const int SiteId = 123;
    private const int ExpiryWindowInDays = 15;

    private const string ExpiringCodesPath = "/codes/v1/expiringcodes/days/15";
    private const string KeycloakTokenPath = "/realms/test/protocol/openid-connect/token";
    private const string LegacyUsersPath = "/legacy/api/v2/users";

    private readonly AlertingTestInfrastructureFixture _fixture;

    public ExpiringPhysicalStampsPollingJobTests(AlertingTestInfrastructureFixture fixture)
    {
        _fixture = fixture;

        DisableExpiringPhysicalStampsJob();
        Sut.WireMock.ResetLogEntries();
    }

    private AlertingTestApplication Sut => _fixture.App;

    [Fact]
    public async Task DoesNotPollCodeService_WhenExpiringPhysicalStampsFeatureIsDisabled()
    {
        // Arrange
        DisableExpiringPhysicalStampsJob();

        StubKeycloakTokenEndpoint();
        StubExpiringCodesEndpointWithPhysicalCodes();

        // Act
        await Task.Delay(TimeSpan.FromSeconds(3), TestContext.Current.CancellationToken);

        // Assert
        GetExpiringCodesRequestCount().Should().Be(
            0,
            "the polling job should not call Code Service when the expiring physical stamps feature flag is disabled");
    }

    [Fact]
    public async Task PollsCodeService_WhenExpiringPhysicalStampsFeatureIsEnabled()
    {
        // Arrange
        StubKeycloakTokenEndpoint();
        StubExpiringCodesEndpointWithPhysicalCodes();
        StubLegacyUsersEndpoint();

        EnableExpiringPhysicalStampsJob();

        // Act
        var codeServiceWasPolled = await WaitUntilAsync(
            () => GetExpiringCodesRequestCount() > 0,
            TimeSpan.FromSeconds(15));

        // Assert
        codeServiceWasPolled.Should().BeTrue(
            "the polling job should call Code Service through Gateway when the feature flag is enabled");
    }

    [Fact]
    public async Task PublishesAndConsumesAlertEvent_WhenCodeServiceReturnsPhysicalCodes()
    {
        // Arrange
        StubKeycloakTokenEndpoint();
        StubExpiringCodesEndpointWithPhysicalCodes();
        StubLegacyUsersEndpoint();

        EnableExpiringPhysicalStampsJob();

        // Act
        var alertEventWasConsumed = await WaitUntilAsync(
            () => GetLegacyUsersRequestCount() > 0,
            TimeSpan.FromSeconds(20));

        // Assert
        GetExpiringCodesRequestCount().Should().BeGreaterThan(
            0,
            "the polling job should poll Code Service before publishing the alert event");

        alertEventWasConsumed.Should().BeTrue(
            "a physical or UCODE expiring code should result in an ExpiringPhysicalStamps alert event being published and consumed");
    }

    [Fact]
    public async Task DoesNotPublishAlertEvent_WhenCodeServiceReturnsOnlyDigitalCodes()
    {
        // Arrange
        StubKeycloakTokenEndpoint();
        StubExpiringCodesEndpointWithDigitalCodesOnly();
        StubLegacyUsersEndpoint();

        EnableExpiringPhysicalStampsJob();

        // Act
        var codeServiceWasPolled = await WaitUntilAsync(
            () => GetExpiringCodesRequestCount() > 0,
            TimeSpan.FromSeconds(15));

        await Task.Delay(TimeSpan.FromSeconds(3), TestContext.Current.CancellationToken);

        // Assert
        codeServiceWasPolled.Should().BeTrue(
            "the polling job should still poll Code Service even when the response contains no physical codes");

        GetLegacyUsersRequestCount().Should().Be(
            0,
            "digital-only codes should not cause an ExpiringPhysicalStamps alert event to be published");
    }

    public void Dispose()
    {
        DisableExpiringPhysicalStampsJob();
    }

    private void EnableExpiringPhysicalStampsJob()
    {
        _fixture.SetFeatureFlags(
            new Dictionary<string, bool>
            {
                [FeatureFlags.SubscriptionManagementEnabled] = true,
                [FeatureFlags.ExpiringPhysicalStampsEnabled] = true
            });
    }

    private void DisableExpiringPhysicalStampsJob()
    {
        _fixture.SetFeatureFlags(
            new Dictionary<string, bool>
            {
                [FeatureFlags.SubscriptionManagementEnabled] = true,
                [FeatureFlags.ExpiringPhysicalStampsEnabled] = false
            });
    }

    private void StubKeycloakTokenEndpoint()
    {
        Sut.WireMock
            .Given(
                Request.Create()
                    .WithPath(KeycloakTokenPath)
                    .UsingPost())
            .RespondWith(
                Response.Create()
                    .WithStatusCode(HttpStatusCode.OK)
                    .WithHeader("Content-Type", "application/json")
                    .WithBodyAsJson(
                        new
                        {
                            access_token = "test-access-token",
                            token_type = "Bearer",
                            expires_in = 3600
                        }));
    }

    private void StubExpiringCodesEndpointWithPhysicalCodes()
    {
        Sut.WireMock
            .Given(
                Request.Create()
                    .WithPath(ExpiringCodesPath)
                    .UsingGet())
            .RespondWith(
                Response.Create()
                    .WithStatusCode(HttpStatusCode.OK)
                    .WithHeader("Content-Type", "application/json")
                    .WithBodyAsJson(
                        new[]
                        {
                            new
                            {
                                siteId = SiteId,
                                siteName = "Manufacturer 1 Site 1",
                                siteGln = "371101.0001.00",
                                expiringCodes = new[]
                                {
                                    new
                                    {
                                        code = "PHYSICAL-CODE-001",
                                        codeType = "Physical"
                                    },
                                    new
                                    {
                                        code = "UCODE-001",
                                        codeType = "Ucode"
                                    },
                                    new
                                    {
                                        code = "DIGITAL-CODE-001",
                                        codeType = "Digital"
                                    }
                                }
                            }
                        }));
    }

    private void StubExpiringCodesEndpointWithDigitalCodesOnly()
    {
        Sut.WireMock
            .Given(
                Request.Create()
                    .WithPath(ExpiringCodesPath)
                    .UsingGet())
            .RespondWith(
                Response.Create()
                    .WithStatusCode(HttpStatusCode.OK)
                    .WithHeader("Content-Type", "application/json")
                    .WithBodyAsJson(
                        new[]
                        {
                            new
                            {
                                siteId = SiteId,
                                siteName = "Manufacturer 1 Site 1",
                                siteGln = "371101.0001.00",
                                expiringCodes = new[]
                                {
                                    new
                                    {
                                        code = "DIGITAL-CODE-001",
                                        codeType = "Digital"
                                    }
                                }
                            }
                        }));
    }

    private void StubLegacyUsersEndpoint()
    {
        var users = new[]
        {
            new
            {
                userId = 1,
                email = "expiring-physical-stamps-user@example.com",
                languageLocale = "en"
            }
        };

        Sut.WireMock
            .Given(
                Request.Create()
                    .WithPath(LegacyUsersPath)
                    .UsingPost())
            .RespondWith(
                Response.Create()
                    .WithStatusCode(HttpStatusCode.OK)
                    .WithHeader("Content-Type", "application/json")
                    .WithBody(JsonSerializer.Serialize(users)));
    }

    private int GetExpiringCodesRequestCount()
    {
        return Sut.WireMock
            .FindLogEntries(
                Request.Create()
                    .WithPath(ExpiringCodesPath)
                    .UsingGet())
            .Count();
    }

    private int GetLegacyUsersRequestCount()
    {
        return Sut.WireMock
            .FindLogEntries(
                Request.Create()
                    .WithPath(LegacyUsersPath)
                    .UsingPost())
            .Count();
    }

    private static async Task<bool> WaitUntilAsync(
        Func<bool> condition,
        TimeSpan timeout)
    {
        var startedAt = DateTime.UtcNow;

        while (DateTime.UtcNow - startedAt < timeout)
        {
            if (condition())
            {
                return true;
            }

            await Task.Delay(TimeSpan.FromMilliseconds(250), TestContext.Current.CancellationToken);
        }

        return false;
    }
}


public AlertingTestApplication CreateApplication()
{
    return new AlertingTestApplication(_resources, _flagsmithClient);
}



using AwesomeAssertions;
using Certify.Alerting.Service.FeatureFlagging;
using Certify.Alerting.Service.Tests.Utils;
using Microsoft.Extensions.Caching.Distributed;
using Microsoft.Extensions.DependencyInjection;
using System.Net;
using System.Text.Json;
using WireMock.RequestBuilders;
using WireMock.ResponseBuilders;
using Xunit;

namespace Certify.Alerting.Service.Tests.Features.ExpiringPhysicalStamps;

[Collection("AlertingTestInfrastructureCollection")]
public sealed class ExpiringPhysicalStampsPollingJobTests
{
    private const int SiteId = 123;

    private const string ExpiringCodesPath = "/codes/v1/expiringcodes/days/15";
    private const string KeycloakTokenPath = "/realms/test/protocol/openid-connect/token";
    private const string JobMetadataCacheKey = "job:metadata:ExpiringPhysicalStampsPollingJob";

    private readonly AlertingTestInfrastructureFixture _fixture;

    public ExpiringPhysicalStampsPollingJobTests(AlertingTestInfrastructureFixture fixture)
    {
        _fixture = fixture;
    }

    [Fact]
    public async Task RunsOnceAndUpdatesMetadata_WhenFeatureSwitchIsEnabledAndJobIsDueAcrossMultipleInstances()
    {
        // Arrange
        await using var app1 = _fixture.CreateApplication();
        await using var app2 = _fixture.CreateApplication();
        await using var app3 = _fixture.CreateApplication();

        await ResetJobMetadata(app1.Services);

        StubKeycloakTokenEndpoint(app1);
        StubExpiringCodesEndpointWithPhysicalCodes(app1);

        var requestCountBeforeRun = GetExpiringCodesRequestCount(app1);
        var startedAtUtc = DateTime.UtcNow;

        EnableExpiringPhysicalStampsJob();

        // Act
        var jobRanSuccessfully = await WaitUntilAsync(
            async () =>
            {
                var metadata = await GetJobMetadata(app1.Services);

                return GetExpiringCodesRequestCount(app1) == requestCountBeforeRun + 1
                    && metadata?.LastSuccessfulRunUtc is not null
                    && metadata.NextRunTimeUtc is not null;
            },
            TimeSpan.FromSeconds(20));

        // Assert
        jobRanSuccessfully.Should().BeTrue(
            "the job should run when the feature switch is enabled and the job is due");

        GetExpiringCodesRequestCount(app1).Should().Be(
            requestCountBeforeRun + 1,
            "only one app instance should acquire the lock and poll Code Service");

        var jobMetadata = await GetJobMetadata(app1.Services);

        jobMetadata.Should().NotBeNull();
        jobMetadata!.LastSuccessfulRunUtc.Should().NotBeNull();
        jobMetadata.LastSuccessfulRunUtc.Should().BeAfter(startedAtUtc);
        jobMetadata.NextRunTimeUtc.Should().NotBeNull();
        jobMetadata.NextRunTimeUtc.Should().BeAfter(DateTime.UtcNow);
    }

    private void EnableExpiringPhysicalStampsJob()
    {
        _fixture.SetFeatureFlags(
            new Dictionary<string, bool>
            {
                [FeatureFlags.SubscriptionManagementEnabled] = true,
                [FeatureFlags.ExpiringPhysicalStampsEnabled] = true
            });
    }

    private static async Task ResetJobMetadata(IServiceProvider services)
    {
        var cache = services.GetRequiredService<IDistributedCache>();

        await cache.RemoveAsync(
            JobMetadataCacheKey,
            TestContext.Current.CancellationToken);
    }

    private static async Task<ExpiringPhysicalStampsJobMetadata?> GetJobMetadata(IServiceProvider services)
    {
        var cache = services.GetRequiredService<IDistributedCache>();

        var metadataBytes = await cache.GetAsync(
            JobMetadataCacheKey,
            TestContext.Current.CancellationToken);

        if (metadataBytes is null)
        {
            return null;
        }

        return JsonSerializer.Deserialize<ExpiringPhysicalStampsJobMetadata>(
            metadataBytes,
            new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });
    }

    private static void StubKeycloakTokenEndpoint(AlertingTestApplication app)
    {
        app.WireMock
            .Given(
                Request.Create()
                    .WithPath(KeycloakTokenPath)
                    .UsingPost())
            .RespondWith(
                Response.Create()
                    .WithStatusCode(HttpStatusCode.OK)
                    .WithHeader("Content-Type", "application/json")
                    .WithBodyAsJson(
                        new
                        {
                            access_token = $"test-access-token-{Guid.NewGuid():N}",
                            token_type = "Bearer",
                            expires_in = 3600
                        }));
    }

    private static void StubExpiringCodesEndpointWithPhysicalCodes(AlertingTestApplication app)
    {
        app.WireMock
            .Given(
                Request.Create()
                    .WithPath(ExpiringCodesPath)
                    .UsingGet())
            .RespondWith(
                Response.Create()
                    .WithStatusCode(HttpStatusCode.OK)
                    .WithHeader("Content-Type", "application/json")
                    .WithBodyAsJson(
                        new[]
                        {
                            new
                            {
                                siteId = SiteId,
                                siteName = "Manufacturer 1 Site 1",
                                siteGln = "371101.0001.00",
                                expiringCodes = new[]
                                {
                                    new
                                    {
                                        code = "PHYSICAL-CODE-001",
                                        codeType = "Physical"
                                    },
                                    new
                                    {
                                        code = "UCODE-001",
                                        codeType = "Ucode"
                                    },
                                    new
                                    {
                                        code = "DIGITAL-CODE-001",
                                        codeType = "Digital"
                                    }
                                }
                            }
                        }));
    }

    private static int GetExpiringCodesRequestCount(AlertingTestApplication app)
    {
        return app.WireMock
            .FindLogEntries(
                Request.Create()
                    .WithPath(ExpiringCodesPath)
                    .UsingGet())
            .Count();
    }

    private static async Task<bool> WaitUntilAsync(
        Func<Task<bool>> condition,
        TimeSpan timeout)
    {
        var startedAt = DateTime.UtcNow;

        while (DateTime.UtcNow - startedAt < timeout)
        {
            if (await condition())
            {
                return true;
            }

            await Task.Delay(
                TimeSpan.FromMilliseconds(250),
                TestContext.Current.CancellationToken);
        }

        return false;
    }

    private sealed class ExpiringPhysicalStampsJobMetadata
    {
        public DateTime? NextRunTimeUtc { get; set; }

        public DateTime? LastSuccessfulRunUtc { get; set; }
    }
}

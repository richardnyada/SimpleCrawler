using Certify.Alerting.Service.Alerts.ExpiringPhysicalStamps.ExpiringPhysicalStampsJob;
using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.DependencyInjection;
using Microsoft.Extensions.Hosting;

namespace Certify.Alerting.Service.Alerts.ExpiringPhysicalStamps;

public static class ExpiringPhysicalStampsServiceCollectionExtensions
{
    public static IServiceCollection AddExpiringPhysicalStampsJobs(
        this IServiceCollection services,
        IConfiguration configuration)
    {
        services.AddOptions<ExpiringPhysicalStampsJobsOptions>()
            .BindConfiguration(ExpiringPhysicalStampsJobsOptions.SectionName)
            .ValidateDataAnnotations()
            .Validate(
                options => options.ExpiryWindowsInDays.Any(),
                "At least one expiry window must be configured for expiring physical stamps jobs.")
            .Validate(
                options => options.ExpiryWindowsInDays.All(expiryWindowInDays => expiryWindowInDays > 0),
                "All expiry windows must be greater than zero.")
            .ValidateOnStart();

        services.AddSingleton<IJobSchedule, JobSchedule>();
        services.AddSingleton<IJobMetadataStore, JobMetadataStore>();

        services.AddScoped<IPollingService, PollingService>();
        services.AddScoped<IAlertPublisher, AlertPublisher>();
        services.AddScoped<IExpiringPhysicalStampsNotificationPayloadBuilder, ExpiringPhysicalStampsNotificationPayloadBuilder>();

        var options = configuration
            .GetSection(ExpiringPhysicalStampsJobsOptions.SectionName)
            .Get<ExpiringPhysicalStampsJobsOptions>()
            ?? throw new InvalidOperationException(
                $"Configuration section '{ExpiringPhysicalStampsJobsOptions.SectionName}' is missing.");

        foreach (var expiryWindowInDays in options.ExpiryWindowsInDays.Distinct())
        {
            var window = expiryWindowInDays;

            services.AddSingleton<IHostedService>(serviceProvider =>
            {
                var jobLockProvider = ActivatorUtilities.CreateInstance<JobLockProvider>(
                    serviceProvider,
                    window);

                var scheduledRunTracker = ActivatorUtilities.CreateInstance<ScheduledRunTracker>(
                    serviceProvider,
                    window);

                var scheduledRunExecutor = ActivatorUtilities.CreateInstance<ScheduledRunExecutor>(
                    serviceProvider,
                    scheduledRunTracker,
                    jobLockProvider,
                    window);

                return ActivatorUtilities.CreateInstance<ExpiringPhysicalStampsPollingJob>(
                    serviceProvider,
                    scheduledRunExecutor,
                    window);
            });
        }

        return services;
    }
}


using AwesomeAssertions;
using Certify.Alerting.Service.Alerts.ExpiringPhysicalStamps.ExpiringPhysicalStampsJob;
using Microsoft.Extensions.Options;
using Moq;
using System;
using System.Threading;
using System.Threading.Tasks;
using Xunit;

namespace Certify.Alerting.Service.Tests.Features.ExpiringPhysicalStamps;

public sealed class ScheduledRunTrackerTests
{
    [Fact]
    public async Task GetOrInitializes_WhenMetadataExists_ReturnsExistingScheduledRun()
    {
        // Arrange
        var cancellationToken = CancellationToken.None;
        var nowUtc = new DateTime(2026, 06, 16, 00, 30, 00, DateTimeKind.Utc);
        var existingNextRunTimeUtc = new DateTime(2026, 06, 16, 01, 00, 00, DateTimeKind.Utc);

        var jobSchedule = new Mock<IJobSchedule>();

        var metadataStore = new Mock<IJobMetadataStore>();
        metadataStore
            .Setup(x => x.GetJobMetadata(cancellationToken))
            .ReturnsAsync(new ExpiringPhysicalStampsJobMetadata
            {
                NextRunTimeUtc = existingNextRunTimeUtc
            });

        var sut = CreateSut(
            jobSchedule: jobSchedule,
            metadataStore: metadataStore);

        // Act
        var result = await sut.GetOrInitializes(nowUtc, cancellationToken);

        // Assert
        result.NextRunTimeUtc.Should().Be(existingNextRunTimeUtc);
        result.WasInitialize.Should().BeFalse();

        jobSchedule.Verify(
            x => x.GetNextRunTimeUtc(It.IsAny<DateTime>()),
            Times.Never);

        metadataStore.Verify(
            x => x.SetJobMetadata(
                It.IsAny<ExpiringPhysicalStampsJobMetadata>(),
                It.IsAny<CancellationToken>()),
            Times.Never);
    }

    [Fact]
    public async Task GetOrInitializes_WhenMetadataIsMissing_InitializesSchedule()
    {
        // Arrange
        var cancellationToken = CancellationToken.None;
        var nowUtc = new DateTime(2026, 06, 16, 00, 30, 00, DateTimeKind.Utc);
        var firstRunTimeUtc = new DateTime(2026, 06, 16, 01, 00, 00, DateTimeKind.Utc);

        var jobSchedule = new Mock<IJobSchedule>();
        jobSchedule
            .Setup(x => x.GetNextRunTimeUtc(nowUtc))
            .Returns(firstRunTimeUtc);

        var metadataStore = new Mock<IJobMetadataStore>();
        metadataStore
            .Setup(x => x.GetJobMetadata(cancellationToken))
            .ReturnsAsync((ExpiringPhysicalStampsJobMetadata?)null);

        var sut = CreateSut(
            jobSchedule: jobSchedule,
            metadataStore: metadataStore);

        // Act
        var result = await sut.GetOrInitializes(nowUtc, cancellationToken);

        // Assert
        result.NextRunTimeUtc.Should().Be(firstRunTimeUtc);
        result.WasInitialize.Should().BeTrue();

        metadataStore.Verify(
            x => x.SetJobMetadata(
                It.Is<ExpiringPhysicalStampsJobMetadata>(metadata =>
                    metadata.NextRunTimeUtc == firstRunTimeUtc),
                cancellationToken),
            Times.Once);
    }

    [Fact]
    public async Task AdvanceToNextRun_UpdatesMetadataAndReturnsNextRunTime()
    {
        // Arrange
        var cancellationToken = CancellationToken.None;
        var nextRunTimeUtc = new DateTime(2026, 06, 17, 01, 00, 00, DateTimeKind.Utc);

        var jobSchedule = new Mock<IJobSchedule>();
        jobSchedule
            .Setup(x => x.GetNextRunTimeUtc(It.IsAny<DateTime>()))
            .Returns(nextRunTimeUtc);

        var metadataStore = new Mock<IJobMetadataStore>();

        var sut = CreateSut(
            jobSchedule: jobSchedule,
            metadataStore: metadataStore);

        // Act
        var result = await sut.AdvanceToNextRun(cancellationToken);

        // Assert
        result.Should().Be(nextRunTimeUtc);

        metadataStore.Verify(
            x => x.SetJobMetadata(
                It.Is<ExpiringPhysicalStampsJobMetadata>(metadata =>
                    metadata.NextRunTimeUtc == nextRunTimeUtc),
                cancellationToken),
            Times.Once);
    }

    [Fact]
    public void ShouldAbandonFailedRun_WhenRetryWindowHasNotElapsed_ReturnsFalse()
    {
        // Arrange
        var nextRunTimeUtc = new DateTime(2026, 06, 16, 01, 00, 00, DateTimeKind.Utc);
        var nowUtc = nextRunTimeUtc.AddMinutes(4);

        var scheduledRun = new ScheduledRun(nextRunTimeUtc);
        var sut = CreateSut(retryWindowMinutes: 5);

        // Act
        var result = sut.ShouldAbandonFailedRun(scheduledRun, nowUtc);

        // Assert
        result.Should().BeFalse();
    }

    [Fact]
    public void ShouldAbandonFailedRun_WhenRetryWindowHasElapsed_ReturnsTrue()
    {
        // Arrange
        var nextRunTimeUtc = new DateTime(2026, 06, 16, 01, 00, 00, DateTimeKind.Utc);
        var nowUtc = nextRunTimeUtc.AddMinutes(5);

        var scheduledRun = new ScheduledRun(nextRunTimeUtc);
        var sut = CreateSut(retryWindowMinutes: 5);

        // Act
        var result = sut.ShouldAbandonFailedRun(scheduledRun, nowUtc);

        // Assert
        result.Should().BeTrue();
    }

    private static ScheduledRunTracker CreateSut(
        int retryWindowMinutes = 5,
        Mock<IJobSchedule>? jobSchedule = null,
        Mock<IJobMetadataStore>? metadataStore = null)
    {
        var options = new DistributedJobsOptions
        {
            LockTimeoutMinutes = 1,
            NextRunIntervalInDays = 1,
            JobMetadataExpirationInDays = 30,
            MissedPollRetryWindowMinutes = retryWindowMinutes,
            RunAtUtc = new TimeSpan(1, 0, 0)
        };

        var optionsMonitor = new Mock<IOptionsMonitor<DistributedJobsOptions>>();
        optionsMonitor
            .Setup(x => x.CurrentValue)
            .Returns(options);

        return new ScheduledRunTracker(
            (jobSchedule ?? new Mock<IJobSchedule>()).Object,
            (metadataStore ?? new Mock<IJobMetadataStore>()).Object,
            optionsMonitor.Object);
    }
}

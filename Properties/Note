
[LoggerMessage(
    EventId = 1000,
    Level = LogLevel.Information,
    Message = "Alerting scheduled job service started.")]
internal static partial void HostedServiceStarted(
    this ILogger logger);

[LoggerMessage(
    EventId = 1001,
    Level = LogLevel.Information,
    Message =
        "Scheduled job leadership acquired by instance {InstanceName}. " +
        "Managing {JobCount} configured jobs and scheduled to recycle at {LeadershipEndsUtc}.")]
internal static partial void SchedulerLeadershipAcquired(
    this ILogger logger,
    string instanceName,
    int jobCount,
    DateTime leadershipEndsUtc);

[LoggerMessage(
    EventId = 1002,
    Level = LogLevel.Error,
    Message =
        "Unexpected error occurred while evaluating scheduled job {JobKey}.")]
internal static partial void UnexpectedError(
    this ILogger logger,
    Exception exception,
    string jobKey);

[LoggerMessage(
    EventId = 1003,
    Level = LogLevel.Information,
    Message =
        "Scheduled job leadership cycle ended for instance {InstanceName}.")]
internal static partial void SchedulerLeadershipEnded(
    this ILogger logger,
    string instanceName);

[LoggerMessage(
    EventId = 1004,
    Level = LogLevel.Information,
    Message = "Alerting scheduled job service stopped.")]
internal static partial void HostedServiceStopped(
    this ILogger logger);

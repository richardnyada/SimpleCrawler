using AwesomeAssertions;
using Certify.Alerting.Service.Alerts.Jobs;
using Medallion.Threading;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Options;
using Moq;
using System;
using System.Threading;
using System.Threading.Tasks;
using Xunit;

namespace Certify.Alerting.Service.Tests.Features.Jobs;

public sealed class ScheduledJobsServiceTests
{
    [Fact]
    public async Task ExecuteAsync_WhenJobEvaluationThrows_DelaysBeforeTryingAgain()
    {
        // Arrange
        const int pollIntervalSeconds = 1;

        var firstAttemptAt = DateTimeOffset.MinValue;

        var secondAttemptSignal =
            new TaskCompletionSource<DateTimeOffset>(
                TaskCreationOptions.RunContinuationsAsynchronously);

        var invocationCount = 0;

        var logger = new Mock<ILogger<ScheduledJobsService>>();

        var scheduledRunExecutor = new Mock<IScheduledRunExecutor>();
        scheduledRunExecutor
            .Setup(x => x.TryExecuteDueRun(
                It.IsAny<ScheduledJobDefinition>(),
                It.IsAny<CancellationToken>()))
            .Callback(() =>
            {
                var currentInvocation =
                    Interlocked.Increment(ref invocationCount);

                if (currentInvocation == 1)
                {
                    firstAttemptAt = DateTimeOffset.UtcNow;
                }

                if (currentInvocation == 2)
                {
                    secondAttemptSignal.TrySetResult(
                        DateTimeOffset.UtcNow);
                }
            })
            .ThrowsAsync(new InvalidOperationException(
                "Test job evaluation exception"));

        var schedulerLock =
            new Mock<IDistributedSynchronizationHandle>();

        var schedulerLockProvider =
            new Mock<ISchedulerLockProvider>();

        schedulerLockProvider
            .Setup(x => x.TryAcquireSchedulerLock(
                It.IsAny<CancellationToken>()))
            .ReturnsAsync(schedulerLock.Object);

        var scheduledJobsOptions =
            new Mock<IOptionsMonitor<ScheduledJobsOptions>>();

        scheduledJobsOptions
            .Setup(x => x.CurrentValue)
            .Returns(new ScheduledJobsOptions
            {
                PollIntervalSeconds = pollIntervalSeconds,
                LeadershipDurationHours = 1,
                JobMetadataExpirationInDays = 30,
                MissedPollRetryWindowMinutes = 5,
                Jobs =
                [
                    new ScheduledJobDefinition
                    {
                        JobName = "TestJob",
                        CronExpression = "0 1 * * *"
                    }
                ]
            });

        var deployModeOptions =
            new Mock<IOptionsMonitor<DeployModeOptions>>();

        deployModeOptions
            .Setup(x => x.CurrentValue)
            .Returns(new DeployModeOptions
            {
                Value = DeployModeOptions.Primary
            });

        var sut = new ScheduledJobsService(
            logger.Object,
            scheduledRunExecutor.Object,
            schedulerLockProvider.Object,
            scheduledJobsOptions.Object,
            deployModeOptions.Object);

        try
        {
            // Act
            await sut.StartAsync(CancellationToken.None);

            var completedTask = await Task.WhenAny(
                secondAttemptSignal.Task,
                Task.Delay(
                    TimeSpan.FromSeconds(pollIntervalSeconds * 3),
                    TestContext.Current.CancellationToken));

            // Assert
            completedTask.Should().Be(
                secondAttemptSignal.Task,
                "the scheduler should evaluate the job again after the poll interval");

            var secondAttemptAt =
                await secondAttemptSignal.Task;

            var elapsedBetweenAttempts =
                secondAttemptAt - firstAttemptAt;

            elapsedBetweenAttempts.Should().BeGreaterThanOrEqualTo(
                TimeSpan.FromMilliseconds(900),
                "an evaluation failure must not cause a tight retry loop");
        }
        finally
        {
            await sut.StopAsync(CancellationToken.None);
        }
    }
}

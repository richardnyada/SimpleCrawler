
protected override async Task ExecuteAsync(
    CancellationToken stoppingToken)
{
    logger.HostedServiceStarted();

    try
    {
        while (!stoppingToken.IsCancellationRequested)
        {
            try
            {
                if (deployModeOptions.CurrentValue.IsPrimary)
                {
                    await using var schedulerLock =
                        await schedulerLockProvider.TryAcquireSchedulerLock(
                            stoppingToken);

                    if (schedulerLock is not null)
                    {
                        await RunLeadershipCycle(stoppingToken);
                    }
                }
            }
            catch (OperationCanceledException)
                when (stoppingToken.IsCancellationRequested)
            {
                throw;
            }
            catch (Exception exception)
            {
                logger.HostedServiceUnexpectedError(exception);
            }

            await Task.Delay(
                TimeSpan.FromSeconds(
                    scheduledJobsOptions.CurrentValue.PollIntervalSeconds),
                stoppingToken);
        }
    }
    catch (OperationCanceledException)
        when (stoppingToken.IsCancellationRequested)
    {
        // Normal service shutdown.
    }
    finally
    {
        logger.HostedServiceStopped();
    }
}


private async Task RunLeadershipCycle(
    CancellationToken stoppingToken)
{
    var leadershipEndsUtc = DateTime.UtcNow.AddHours(
        scheduledJobsOptions.CurrentValue.LeadershipDurationHours);

    logger.SchedulerLeadershipAcquired(
        scheduledJobsOptions.CurrentValue.Jobs.Count,
        leadershipEndsUtc);

    while (
        DateTime.UtcNow < leadershipEndsUtc &&
        deployModeOptions.CurrentValue.IsPrimary)
    {
        foreach (var job in scheduledJobsOptions.CurrentValue.Jobs)
        {
            try
            {
                await scheduledRunExecutor.TryExecuteDueRun(
                    job,
                    stoppingToken);
            }
            catch (OperationCanceledException)
                when (stoppingToken.IsCancellationRequested)
            {
                throw;
            }
            catch (Exception exception)
            {
                logger.UnexpectedError(exception, job.Key);
            }
        }

        await Task.Delay(
            TimeSpan.FromSeconds(
                scheduledJobsOptions.CurrentValue.PollIntervalSeconds),
            stoppingToken);
    }

    logger.SchedulerLeadershipEnded();
}
